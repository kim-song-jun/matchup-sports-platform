# Database
DATABASE_URL=postgresql://teameet_user:teameet_password@localhost:5433/teameet_dev
REDIS_URL=redis://localhost:6380/0

# API
API_PORT=8111
API_PREFIX=/api/v1
NODE_ENV=development

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OAuth (Kakao)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao/callback

# OAuth (Naver)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/oauth/naver/callback

# OAuth (Apple)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Payment (Toss Payments)
TOSS_CLIENT_KEY=test_ck_xxx
TOSS_SECRET_KEY=test_sk_xxx

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=teameet-dev

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@teameet.kr

# CORS
FRONTEND_URL=https://teameet.kr

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8111/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:8111
