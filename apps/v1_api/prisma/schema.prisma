generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum V1AccountStatus {
  active
  suspended
  blocked
  withdrawal_pending
  deleted
}

enum V1OnboardingStatus {
  not_started
  terms_done
  social_terms_required
  social_profile_required
  signup_done
  sport_done
  level_done
  region_done
  completed
  deferred
}

enum V1AuthProvider {
  kakao
  naver
  email
}

enum V1AuthIdentityStatus {
  active
  unlinked
  blocked
}

enum V1TermsDocumentStatus {
  draft
  published
  archived
}

enum V1TermsKind {
  terms
  privacy
  marketing
}

enum V1NoticeAudience {
  public
  users
  admins
}

enum V1NoticeStatus {
  draft
  published
  archived
}

enum V1TrustState {
  verified
  estimated
  sample
  none
}

enum V1MatchStatus {
  recruiting
  closed
  cancelled
  completed
  archived
}

enum V1MatchApplicationStatus {
  requested
  approved
  rejected
  withdrawn
  cancelled_by_host
  expired
}

enum V1MatchParticipantRole {
  host
  participant
}

enum V1MatchParticipantStatus {
  active
  removed
  cancelled
  no_show
  completed
}

enum V1TeamStatus {
  active
  suspended
  archived
}

enum V1TeamJoinPolicy {
  approval_required
  closed
}

enum V1TeamMembershipRole {
  owner
  manager
  member
}

enum V1TeamMembershipStatus {
  active
  removed
  left
}

enum V1TeamJoinApplicationStatus {
  requested
  approved
  rejected
  withdrawn
  expired
}

enum V1TeamInvitationStatus {
  pending
  accepted
  declined
  cancelled
}

enum V1TeamMatchStatus {
  recruiting
  closed
  matched
  cancelled
  completed
  archived
}

enum V1TeamMatchApplicationStatus {
  requested
  approved
  rejected
  withdrawn
  expired
}

enum V1PostEventReviewSourceType {
  match
  team_match
}

enum V1PostEventReviewTargetType {
  user
  team
}

enum V1PostEventReviewStatus {
  submitted
  hidden
  removed
}

enum V1ChatRoomStatus {
  active
  archived
}

enum V1ChatParticipantStatus {
  active
  left
}

enum V1ChatMessageStatus {
  sent
  hidden
  deleted
}

enum V1ChatMessageType {
  text
  system
}

enum V1ChatSystemEventType {
  joined
  left
}

enum V1NotificationTargetType {
  match
  team
  team_match
  chat
  notice
  system
  tournament
}

enum V1AdminRole {
  owner
  ops
  support
}

enum V1AdminStatus {
  active
  suspended
  revoked
}

enum V1ContentAssetStatus {
  temporary
  attached
}

enum V1StatusActorType {
  user
  admin
  system
}

enum V1InquiryCategory {
  account
  match
  team
  tournament
  payment_refund
  report
  other
}

enum V1InquiryStatus {
  received
  reviewing
  answered
  closed
}

enum V1InquiryRelatedType {
  match
  team
  team_match
  tournament
  registration
  payment
  user
}

model V1RuntimeCheck {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("v1_runtime_checks")
}

model V1User {
  id               String             @id @default(uuid())
  email            String?            @unique
  phone            String?            @unique
  accountStatus    V1AccountStatus    @default(active) @map("account_status")
  onboardingStatus V1OnboardingStatus @default(not_started) @map("onboarding_status")
  lastLoginAt      DateTime?          @map("last_login_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  emailVerifiedAt  DateTime?          @map("email_verified_at")
  phoneVerifiedAt  DateTime?          @map("phone_verified_at")

  authIdentities                 V1AuthIdentity[]
  profile                        V1UserProfile?
  onboardingProgress             V1UserOnboardingProgress?
  termsConsents                  V1UserTermsConsent[]
  sportPreferences               V1UserSportPreference[]
  regions                        V1UserRegion[]
  reputationSummary              V1UserReputationSummary?
  hostedMatches                  V1Match[]                  @relation("V1MatchHost")
  matchApplications              V1MatchApplication[]       @relation("V1MatchApplicant")
  reviewedApplications           V1MatchApplication[]       @relation("V1MatchApplicationReviewer")
  matchParticipants              V1MatchParticipant[]
  ownedTeams                     V1Team[]                   @relation("V1TeamOwner")
  teamMemberships                V1TeamMembership[]         @relation("V1TeamMember")
  removedTeamMemberships         V1TeamMembership[]         @relation("V1TeamMembershipRemover")
  teamJoinApplications           V1TeamJoinApplication[]    @relation("V1TeamJoinApplicant")
  reviewedTeamJoins              V1TeamJoinApplication[]    @relation("V1TeamJoinReviewer")
  teamInvitesReceived            V1TeamInvitation[]         @relation("V1TeamInvitee")
  teamInvitesSent                V1TeamInvitation[]         @relation("V1TeamInviter")
  createdTeamMatches             V1TeamMatch[]              @relation("V1TeamMatchCreator")
  teamMatchApplications          V1TeamMatchApplication[]   @relation("V1TeamMatchApplicantUser")
  reviewedTeamMatches            V1TeamMatchApplication[]   @relation("V1TeamMatchReviewer")
  chatParticipations             V1ChatRoomParticipant[]
  chatMessages                   V1ChatMessage[]            @relation("V1ChatMessageSender")
  notifications                  V1Notification[]
  notificationPreference         V1NotificationPreference?
  searchHistories                V1SearchHistory[]
  adminUser                      V1AdminUser?               @relation("V1AdminUserAccount")
  grantedAdmins                  V1AdminUser[]              @relation("V1AdminGrantor")
  statusLogs                     V1StatusChangeLog[]        @relation("V1StatusActorUser")
  postEventReviewsWritten        V1PostEventReview[]        @relation("V1PostEventReviewReviewer")
  postEventUserReviewsReceived   V1PostEventReview[]        @relation("V1PostEventReviewTargetUser")
  tournamentRegistrationsApplied V1TournamentRegistration[] @relation("V1TournamentRegistrationApplicant")
  tournamentPlayerEntries        V1TournamentPlayer[]
  verificationTokens             V1VerificationToken[]
  inquiries                       V1Inquiry[]

  @@index([accountStatus])
  @@index([onboardingStatus])
  @@index([createdAt])
  @@map("v1_users")
}

model V1AuthIdentity {
  id              String               @id @default(uuid())
  userId          String               @map("user_id")
  provider        V1AuthProvider
  providerUserKey String               @map("provider_user_key")
  email           String?
  passwordHash    String?              @map("password_hash")
  status          V1AuthIdentityStatus @default(active)
  lastLoginAt     DateTime?            @map("last_login_at")
  unlinkedAt      DateTime?            @map("unlinked_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  user V1User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserKey])
  @@index([userId])
  @@index([status])
  @@map("v1_auth_identities")
}

enum V1VerificationChannel {
  email
  phone
}

model V1VerificationToken {
  id           String                @id @default(uuid())
  userId       String                @map("user_id")
  channel      V1VerificationChannel
  target       String
  codeHash     String                @map("code_hash")
  expiresAt    DateTime              @map("expires_at")
  consumedAt   DateTime?             @map("consumed_at")
  attemptCount Int                   @default(0) @map("attempt_count")
  createdAt    DateTime              @default(now()) @map("created_at")

  user V1User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
  @@map("v1_verification_tokens")
}

model V1UserProfile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  nickname        String
  gender          String?
  birthDate       String?   @map("birth_date")
  profileImageUrl String?   @map("profile_image_url")
  bio             String?
  visibility      String    @default("public")
  displayName     String?   @map("display_name")
  realName        String?   @map("real_name")
  displayRegion   String?   @map("display_region")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  user V1User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nickname])
  @@map("v1_user_profiles")
}

model V1UserOnboardingProgress {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  currentStep String    @default("terms") @map("current_step")
  draftJson   Json?     @map("draft_json")
  completedAt DateTime? @map("completed_at")
  deferredAt  DateTime? @map("deferred_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user V1User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("v1_user_onboarding_progress")
}

model V1TermsDocument {
  id          String                @id @default(uuid())
  kind        V1TermsKind
  version     String
  title       String
  content     String
  status      V1TermsDocumentStatus @default(draft)
  isRequired  Boolean               @default(true) @map("is_required")
  publishedAt DateTime?             @map("published_at")
  archivedAt  DateTime?             @map("archived_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  consents V1UserTermsConsent[]

  @@unique([kind, version])
  @@index([status])
  @@index([createdAt])
  @@map("v1_terms_documents")
}

model V1UserTermsConsent {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  termsDocumentId String    @map("terms_document_id")
  acceptedAt      DateTime  @default(now()) @map("accepted_at")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user          V1User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  termsDocument V1TermsDocument @relation(fields: [termsDocumentId], references: [id], onDelete: Restrict)

  @@unique([userId, termsDocumentId])
  @@index([termsDocumentId])
  @@map("v1_user_terms_consents")
}

model V1Sport {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  levels          V1SportLevel[]
  userPreferences V1UserSportPreference[]
  matches         V1Match[]
  teams           V1Team[]
  teamMatches     V1TeamMatch[]
  tournaments     V1Tournament[]

  @@index([isActive, sortOrder])
  @@map("v1_sports")
}

model V1SportLevel {
  id          String   @id @default(uuid())
  sportId     String   @map("sport_id")
  code        String
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sport           V1Sport                 @relation(fields: [sportId], references: [id], onDelete: Cascade)
  userPreferences V1UserSportPreference[]
  minMatches      V1Match[]               @relation("V1MatchMinSportLevel")
  maxMatches      V1Match[]               @relation("V1MatchMaxSportLevel")
  minTeamProfiles V1TeamProfile[]         @relation("V1TeamProfileMinSportLevel")
  maxTeamProfiles V1TeamProfile[]         @relation("V1TeamProfileMaxSportLevel")
  minTeamMatches  V1TeamMatch[]           @relation("V1TeamMatchMinSportLevel")
  maxTeamMatches  V1TeamMatch[]           @relation("V1TeamMatchMaxSportLevel")

  @@unique([sportId, code])
  @@index([sportId, isActive, sortOrder])
  @@map("v1_sport_levels")
}

model V1Region {
  id        String   @id @default(uuid())
  parentId  String?  @map("parent_id")
  code      String   @unique
  name      String
  level     Int
  centerLat Float?   @map("center_lat")
  centerLng Float?   @map("center_lng")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent      V1Region?      @relation("V1RegionTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    V1Region[]     @relation("V1RegionTree")
  userRegions V1UserRegion[]
  matches     V1Match[]
  teams       V1Team[]
  teamMatches V1TeamMatch[]

  @@index([parentId])
  @@index([level, isActive, sortOrder])
  @@map("v1_regions")
}

model V1Notice {
  id          String           @id @default(uuid())
  audience    V1NoticeAudience @default(public)
  category    String           @default("안내")
  title       String
  body        String
  contentJson Json?            @map("content_json")
  contentVersion Int           @default(1) @map("content_version")
  status      V1NoticeStatus   @default(draft)
  publishedAt DateTime?        @map("published_at")
  archivedAt  DateTime?        @map("archived_at")
  displayStartAt DateTime?     @map("display_start_at")
  displayEndAt   DateTime?     @map("display_end_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  contentAssets V1ContentAsset[]

  @@index([audience, status, publishedAt])
  @@index([category, status, displayStartAt, displayEndAt], map: "v1_notices_popup_display_window_idx")
  @@index([category, status, publishedAt])
  @@index([createdAt])
  @@map("v1_notices")
}

model V1Popup {
  id             String           @id @default(uuid())
  audience       V1NoticeAudience @default(public)
  title          String
  body           String
  contentJson    Json?            @map("content_json")
  contentVersion Int              @default(1) @map("content_version")
  targetScreens  String[]         @default(["home"]) @map("target_screens")
  linkUrl        String?          @map("link_url")
  linkLabel      String?          @map("link_label")
  status         V1NoticeStatus   @default(draft)
  publishedAt    DateTime?        @map("published_at")
  archivedAt     DateTime?        @map("archived_at")
  displayStartAt DateTime?        @map("display_start_at")
  displayEndAt   DateTime?        @map("display_end_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  contentAssets  V1ContentAsset[]

  @@index([audience, status, displayStartAt, displayEndAt, publishedAt], map: "v1_popups_active_window_idx")
  @@index([createdAt])
  @@map("v1_popups")
}

model V1ContentAsset {
  id                    String               @id @default(uuid())
  url                   String               @unique
  storagePath           String               @unique @map("storage_path")
  status                V1ContentAssetStatus @default(temporary)
  uploadedByAdminUserId String               @map("uploaded_by_admin_user_id")
  noticeId              String?              @map("notice_id")
  popupId               String?              @map("popup_id")
  attachedAt            DateTime?            @map("attached_at")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  uploadedByAdminUser V1AdminUser @relation(fields: [uploadedByAdminUserId], references: [id], onDelete: Restrict)
  notice             V1Notice?    @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  popup              V1Popup?     @relation(fields: [popupId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([uploadedByAdminUserId, createdAt])
  @@index([noticeId])
  @@index([popupId])
  @@map("v1_content_assets")
}

model V1UserSportPreference {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sportId      String   @map("sport_id")
  sportLevelId String?  @map("sport_level_id")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       V1User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport      V1Sport       @relation(fields: [sportId], references: [id], onDelete: Restrict)
  sportLevel V1SportLevel? @relation(fields: [sportLevelId], references: [id], onDelete: SetNull)

  @@unique([userId, sportId])
  @@index([sportId])
  @@index([sportLevelId])
  @@map("v1_user_sport_preferences")
}

model V1UserRegion {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  regionId  String   @map("region_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   V1User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  region V1Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  @@unique([userId, regionId])
  @@index([regionId])
  @@map("v1_user_regions")
}

model V1UserReputationSummary {
  id           String       @id @default(uuid())
  userId       String       @unique @map("user_id")
  trustState   V1TrustState @default(sample) @map("trust_state")
  mannerScore  Decimal?     @map("manner_score") @db.Decimal(4, 2)
  reviewCount  Int          @default(0) @map("review_count")
  sourceLabel  String?      @map("source_label")
  calculatedAt DateTime?    @map("calculated_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user V1User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trustState])
  @@map("v1_user_reputation_summaries")
}

model V1Match {
  id              String        @id @default(uuid())
  hostUserId      String        @map("host_user_id")
  sportId         String        @map("sport_id")
  regionId        String?       @map("region_id")
  title           String
  description     String?
  imageUrl        String?       @map("image_url")
  placeName       String        @map("place_name")
  placeAddress    String?       @map("place_address")
  startAt         DateTime      @map("start_at")
  endAt           DateTime?     @map("end_at")
  deadlineAt      DateTime?     @map("deadline_at")
  maxParticipants Int           @map("max_participants")
  levelNote       String?       @map("level_note")
  minSportLevelId String?       @map("min_sport_level_id")
  maxSportLevelId String?       @map("max_sport_level_id")
  genderRule      String?       @map("gender_rule")
  costNote        String?       @map("cost_note")
  status          V1MatchStatus @default(recruiting)
  cancelledAt     DateTime?     @map("cancelled_at")
  completedAt     DateTime?     @map("completed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  hostUser      V1User               @relation("V1MatchHost", fields: [hostUserId], references: [id], onDelete: Restrict)
  sport         V1Sport              @relation(fields: [sportId], references: [id], onDelete: Restrict)
  minSportLevel V1SportLevel?        @relation("V1MatchMinSportLevel", fields: [minSportLevelId], references: [id], onDelete: SetNull)
  maxSportLevel V1SportLevel?        @relation("V1MatchMaxSportLevel", fields: [maxSportLevelId], references: [id], onDelete: SetNull)
  region        V1Region?            @relation(fields: [regionId], references: [id], onDelete: Restrict)
  applications  V1MatchApplication[]
  participants  V1MatchParticipant[]
  chatRoom      V1ChatRoom?

  @@index([hostUserId])
  @@index([sportId, regionId, status, startAt])
  @@index([minSportLevelId])
  @@index([maxSportLevelId])
  @@index([status])
  @@index([startAt])
  @@index([createdAt])
  @@map("v1_matches")
}

model V1MatchApplication {
  id               String                   @id @default(uuid())
  matchId          String                   @map("match_id")
  applicantUserId  String                   @map("applicant_user_id")
  status           V1MatchApplicationStatus @default(requested)
  message          String?
  reviewedByUserId String?                  @map("reviewed_by_user_id")
  reviewedAt       DateTime?                @map("reviewed_at")
  withdrawnAt      DateTime?                @map("withdrawn_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  match          V1Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  applicantUser  V1User              @relation("V1MatchApplicant", fields: [applicantUserId], references: [id], onDelete: Restrict)
  reviewedByUser V1User?             @relation("V1MatchApplicationReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  participant    V1MatchParticipant?

  @@unique([matchId, applicantUserId])
  @@index([applicantUserId, status])
  @@index([status])
  @@index([createdAt])
  @@map("v1_match_applications")
}

model V1MatchParticipant {
  id            String                   @id @default(uuid())
  matchId       String                   @map("match_id")
  userId        String                   @map("user_id")
  applicationId String?                  @unique @map("application_id")
  role          V1MatchParticipantRole   @default(participant)
  status        V1MatchParticipantStatus @default(active)
  approvedAt    DateTime?                @map("approved_at")
  cancelledAt   DateTime?                @map("cancelled_at")
  completedAt   DateTime?                @map("completed_at")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  match       V1Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user        V1User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  application V1MatchApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@unique([matchId, userId])
  @@index([userId, status])
  @@index([role, status])
  @@map("v1_match_participants")
}

model V1Team {
  id             String           @id @default(uuid())
  ownerUserId    String           @map("owner_user_id")
  sportId        String           @map("sport_id")
  regionId       String           @map("region_id")
  name           String
  status         V1TeamStatus     @default(active)
  joinPolicy     V1TeamJoinPolicy @default(approval_required) @map("join_policy")
  membersVisible Boolean          @default(true) @map("members_visible")
  memberCount    Int              @default(1) @map("member_count")
  managerCount   Int              @default(0) @map("manager_count")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  ownerUser                    V1User                     @relation("V1TeamOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  sport                        V1Sport                    @relation(fields: [sportId], references: [id], onDelete: Restrict)
  region                       V1Region                   @relation(fields: [regionId], references: [id], onDelete: Restrict)
  profile                      V1TeamProfile?
  memberships                  V1TeamMembership[]
  joinApplications             V1TeamJoinApplication[]
  invitations                  V1TeamInvitation[]
  trustScore                   V1TeamTrustScore?
  hostedTeamMatches            V1TeamMatch[]              @relation("V1HostTeamMatches")
  approvedTeamMatches          V1TeamMatch[]              @relation("V1ApprovedApplicantTeam")
  teamMatchApplications        V1TeamMatchApplication[]   @relation("V1TeamMatchApplicantTeam")
  chatRoom                     V1ChatRoom?
  postEventReviewsWritten      V1PostEventReview[]        @relation("V1PostEventReviewReviewerTeam")
  postEventTeamReviewsReceived V1PostEventReview[]        @relation("V1PostEventReviewTargetTeam")
  tournamentRegistrations      V1TournamentRegistration[]

  @@index([ownerUserId])
  @@index([sportId, regionId, status])
  @@index([status])
  @@index([createdAt])
  @@map("v1_teams")
}

model V1TeamProfile {
  id              String    @id @default(uuid())
  teamId          String    @unique @map("team_id")
  logoUrl         String?   @map("logo_url")
  coverImageUrl   String?   @map("cover_image_url")
  description     String?
  activityNote    String?   @map("activity_note")
