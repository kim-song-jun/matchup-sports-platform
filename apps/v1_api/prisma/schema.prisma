// ---------------------------------------------------------------------------
// Tournament domain (Wave 2-3) — 풋살 토너먼트. 팀 단위 참가 신청 + 명단 +
// 결제(PG/계좌이체 택1) + 어드민 수동 운영(대진/결과/순위/공지).
// ---------------------------------------------------------------------------

enum V1TournamentStatus {
  draft
  open
  closed
  in_progress
  completed
  cancelled
}

enum V1TournamentFormat {
  league
  knockout
  group_knockout
}

enum V1TournamentRegistrationStatus {
  draft
  submitted
  awaiting_payment
  payment_checking
  paid
  confirmed
  waitlisted
  cancel_requested
  cancelled
}

enum V1TournamentPaymentMethod {
  pg
  bank_transfer
}

enum V1TournamentPaymentStatus {
  ready
  paid
  failed
  cancelled
  refunded
}

enum V1TournamentPlayerEligibility {
  non_pro
  pro
  needs_review
}

enum V1TournamentGroupPhase {
  group
  semi
  final
  third_place
}

enum V1TournamentFixtureStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum V1TournamentAnnouncementAudience {
  public
  all_registered
  confirmed_only
  waitlist
}

model V1Tournament {
  id                     String             @id @default(uuid())
  sportId                String             @map("sport_id")
  title                  String
  status                 V1TournamentStatus @default(draft)
  format                 V1TournamentFormat @default(group_knockout)
  registrationDeadlineAt DateTime?          @map("registration_deadline_at")
  scheduledAt            DateTime?          @map("scheduled_at")
  scheduledEndAt         DateTime?          @map("scheduled_end_at")
  venue                  String?
  teamCount              Int                @default(8) @map("team_count")
  minPlayers             Int                @default(6) @map("min_players")
  maxPlayers             Int                @default(10) @map("max_players")
  entryFee               Int                @default(0) @map("entry_fee")
  // 상금: prizeSummary=대표 상품/상금 문구, prizeBreakdown=순위별 안내 텍스트(예: "1위 100만원 · 2위 50만원"). prizePool은 하위 호환용 숫자 필드.
  prizePool              Int?               @map("prize_pool")
  prizeSummary           String?            @map("prize_summary")
  prizeBreakdown         String?            @map("prize_breakdown")
  promoHomeEnabled       Boolean            @default(false) @map("promo_home_enabled")
  promoHomeTitle         String?            @map("promo_home_title")
  promoHomeSubtitle      String?            @map("promo_home_subtitle")
  promoHomeImageUrl      String?            @map("promo_home_image_url")
  promoHomeBadgeText     String?            @map("promo_home_badge_text")
  promoHomeDateText      String?            @map("promo_home_date_text")
  promoHomeTeamsText     String?            @map("promo_home_teams_text")
  promoHomeLocationText  String?            @map("promo_home_location_text")
  promoHomePrizeText     String?            @map("promo_home_prize_text")
  promoHomePriority      Int                @default(0) @map("promo_home_priority")
  promoListEnabled       Boolean            @default(false) @map("promo_list_enabled")
  promoListTitle         String?            @map("promo_list_title")
  promoListSubtitle      String?            @map("promo_list_subtitle")
  promoListImageUrl      String?            @map("promo_list_image_url")
  promoListBadgeText     String?            @map("promo_list_badge_text")
  promoListDateText      String?            @map("promo_list_date_text")
  promoListTeamsText     String?            @map("promo_list_teams_text")
  promoListLocationText  String?            @map("promo_list_location_text")
  promoListPrizeText     String?            @map("promo_list_prize_text")
  promoListPriority      Int                @default(0) @map("promo_list_priority")
  bankName               String?            @map("bank_name")
  bankAccount            String?            @map("bank_account")
  bankHolder             String?            @map("bank_holder")
  rulesText              String?            @map("rules_text")
  refundPolicyText       String?            @map("refund_policy_text")
  createdByAdminUserId   String?            @map("created_by_admin_user_id")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  sport          V1Sport                    @relation(fields: [sportId], references: [id], onDelete: Restrict)
  createdByAdmin V1AdminUser?               @relation("V1TournamentCreatedByAdmin", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  registrations  V1TournamentRegistration[]
  groups         V1TournamentGroup[]
  fixtures       V1TournamentFixture[]
  announcements  V1TournamentAnnouncement[]

  @@index([status, scheduledAt])
  @@index([sportId, status])
  @@map("v1_tournaments")
}

model V1TournamentRegistration {
  id                     String                         @id @default(uuid())
  tournamentId           String                         @map("tournament_id")
  teamId                 String                         @map("team_id")
  appliedByUserId        String                         @map("applied_by_user_id")
  status                 V1TournamentRegistrationStatus @default(draft)
  depositorName          String?                        @map("depositor_name")
  agreedRules            Boolean                        @default(false) @map("agreed_rules")
  agreedPrivacy          Boolean                        @default(false) @map("agreed_privacy")
  agreedRefund           Boolean                        @default(false) @map("agreed_refund")
  agreedMediaConsent     Boolean                        @default(false) @map("agreed_media_consent")
  confirmedByAdminUserId String?                        @map("confirmed_by_admin_user_id")
  confirmedAt            DateTime?                      @map("confirmed_at")
  rosterLockedAt         DateTime?                      @map("roster_locked_at")
  cancelRequestedAt      DateTime?                      @map("cancel_requested_at")
  cancelPreviousStatus   V1TournamentRegistrationStatus? @map("cancel_previous_status")
  cancelReason           String?                        @map("cancel_reason")
  createdAt              DateTime                       @default(now()) @map("created_at")
  updatedAt              DateTime                       @updatedAt @map("updated_at")

  tournament       V1Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team             V1Team                  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  appliedByUser    V1User                  @relation("V1TournamentRegistrationApplicant", fields: [appliedByUserId], references: [id], onDelete: Restrict)
  confirmedByAdmin V1AdminUser?            @relation("V1TournamentRegistrationConfirmedByAdmin", fields: [confirmedByAdminUserId], references: [id], onDelete: SetNull)
  players          V1TournamentPlayer[]
  payment          V1TournamentPayment?
  groupTeams       V1TournamentGroupTeam[]
  homeFixtures     V1TournamentFixture[]   @relation("V1TournamentFixtureHome")
  awayFixtures     V1TournamentFixture[]   @relation("V1TournamentFixtureAway")
  standings        V1TournamentStanding[]

  @@unique([tournamentId, teamId])
  @@index([tournamentId, status])
  @@index([teamId])
  @@index([appliedByUserId])
  @@map("v1_tournament_registrations")
}

model V1TournamentPlayer {
  id                String                        @id @default(uuid())
  registrationId    String                        @map("registration_id")
  userId            String                        @map("user_id")
  realName          String                        @map("real_name")
  birthDateSnapshot String?                       @map("birth_date_snapshot")
  genderSnapshot    String?                       @map("gender_snapshot")
  eligibilityStatus V1TournamentPlayerEligibility @default(needs_review) @map("eligibility_status")
  eligibilityNote   String?                       @map("eligibility_note")
  addedAt           DateTime                      @default(now()) @map("added_at")
  removedAt         DateTime?                     @map("removed_at")
  createdAt         DateTime                      @default(now()) @map("created_at")
  updatedAt         DateTime                      @updatedAt @map("updated_at")

  registration V1TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  user         V1User                   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([registrationId, userId])
  @@index([registrationId, removedAt])
  @@index([userId])
  @@index([eligibilityStatus])
  @@map("v1_tournament_players")
}

model V1TournamentPayment {
  id                     String                    @id @default(uuid())
  registrationId         String                    @unique @map("registration_id")
  method                 V1TournamentPaymentMethod
  provider               String?
  providerTxId           String?                   @map("provider_tx_id")
  amount                 Int
  status                 V1TournamentPaymentStatus @default(ready)
  paidAt                 DateTime?                 @map("paid_at")
  cancelledAt            DateTime?                 @map("cancelled_at")
  refundedAt             DateTime?                 @map("refunded_at")
  confirmedByAdminUserId String?                   @map("confirmed_by_admin_user_id")
  rawWebhookRef          String?                   @map("raw_webhook_ref")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")

  registration     V1TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  confirmedByAdmin V1AdminUser?             @relation("V1TournamentPaymentConfirmedByAdmin", fields: [confirmedByAdminUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([providerTxId])
  @@map("v1_tournament_payments")
}

model V1TournamentGroup {
  id           String                 @id @default(uuid())
  tournamentId String                 @map("tournament_id")
  name         String
  phase        V1TournamentGroupPhase @default(group)
  sortOrder    Int                    @default(0) @map("sort_order")
  // 이 조에서 상위 몇 팀이 다음 단계로 진출하는지(조별리그 진출선 표시용). null이면 진출 표시 없음.
  advanceCount Int?                   @map("advance_count")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  tournament V1Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groupTeams V1TournamentGroupTeam[]
  fixtures   V1TournamentFixture[]
  standings  V1TournamentStanding[]

  @@index([tournamentId, phase, sortOrder])
  @@map("v1_tournament_groups")
}

model V1TournamentGroupTeam {
  id             String   @id @default(uuid())
  groupId        String   @map("group_id")
  registrationId String   @map("registration_id")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  group        V1TournamentGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  registration V1TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([groupId, registrationId])
  @@index([registrationId])
  @@map("v1_tournament_group_teams")
}

model V1TournamentFixture {
  id                 String                    @id @default(uuid())
  tournamentId       String                    @map("tournament_id")
  groupId            String?                   @map("group_id")
  round              String
  fixtureNumber      Int                       @map("fixture_number")
  legNumber          Int                       @default(1) @map("leg_number")
  parentFixtureId    String?                   @map("parent_fixture_id")
  homeRegistrationId String?                   @map("home_registration_id")
  awayRegistrationId String?                   @map("away_registration_id")
  scheduledAt        DateTime?                 @map("scheduled_at")
  venue              String?
  status             V1TournamentFixtureStatus @default(scheduled)
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  tournament       V1Tournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group            V1TournamentGroup?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  parentFixture    V1TournamentFixture?       @relation("V1TournamentFixtureParent", fields: [parentFixtureId], references: [id], onDelete: SetNull)
  childFixtures    V1TournamentFixture[]      @relation("V1TournamentFixtureParent")
  homeRegistration V1TournamentRegistration?  @relation("V1TournamentFixtureHome", fields: [homeRegistrationId], references: [id], onDelete: SetNull)
  awayRegistration V1TournamentRegistration?  @relation("V1TournamentFixtureAway", fields: [awayRegistrationId], references: [id], onDelete: SetNull)
  result           V1TournamentFixtureResult?

  @@index([tournamentId, round, fixtureNumber])
  @@index([groupId])
  @@index([parentFixtureId])
  @@map("v1_tournament_fixtures")
}

model V1TournamentFixtureResult {
  id                    String   @id @default(uuid())
  fixtureId             String   @unique @map("fixture_id")
  homeScore             Int      @default(0) @map("home_score")
  awayScore             Int      @default(0) @map("away_score")
  hasPenalty            Boolean  @default(false) @map("has_penalty")
  homePenaltyScore      Int?     @map("home_penalty_score")
  awayPenaltyScore      Int?     @map("away_penalty_score")
  note                  String?
  recordedByAdminUserId String?  @map("recorded_by_admin_user_id")
  recordedAt            DateTime @default(now()) @map("recorded_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  fixture         V1TournamentFixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  recordedByAdmin V1AdminUser?        @relation("V1TournamentFixtureResultRecordedByAdmin", fields: [recordedByAdminUserId], references: [id], onDelete: SetNull)

  @@map("v1_tournament_fixture_results")
}

model V1TournamentStanding {
  id             String    @id @default(uuid())
  groupId        String    @map("group_id")
  registrationId String    @map("registration_id")
  points         Int       @default(0)
  wins           Int       @default(0)
  draws          Int       @default(0)
  losses         Int       @default(0)
  goalsFor       Int       @default(0) @map("goals_for")
  goalsAgainst   Int       @default(0) @map("goals_against")
  position       Int?
  recalculatedAt DateTime? @map("recalculated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  group        V1TournamentGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  registration V1TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([groupId, registrationId])
  @@index([groupId, position])
  @@map("v1_tournament_standings")
}

model V1TournamentAnnouncement {
  id           String                           @id @default(uuid())
  tournamentId String                           @map("tournament_id")
  title        String
  body         String
  audience     V1TournamentAnnouncementAudience @default(all_registered)
  publishedAt  DateTime?                        @map("published_at")
  createdAt    DateTime                         @default(now()) @map("created_at")
  updatedAt    DateTime                         @updatedAt @map("updated_at")

  tournament V1Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, publishedAt])
  @@map("v1_tournament_announcements")
}
