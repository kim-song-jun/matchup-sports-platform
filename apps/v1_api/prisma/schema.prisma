  updatedAt         DateTime               @updatedAt @map("updated_at")

  settlementBatch V1SettlementBatch  @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)
  seller          V1SettlementSeller @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([settlementBatchId, status])
  @@index([sellerId, createdAt])
  @@index([sourceType, sourceId])
  @@map("v1_settlement_items")
}

model V1PayoutAttempt {
  id                     String                @id @default(uuid())
  settlementBatchId      String                @map("settlement_batch_id")
  requestedByAdminUserId String                @map("requested_by_admin_user_id")
  providerPayoutId       String?               @map("provider_payout_id")
  status                 V1PayoutAttemptStatus @default(requested)
  amount                 Int
  requestedAt            DateTime              @default(now()) @map("requested_at")
  providerConfirmedAt    DateTime?             @map("provider_confirmed_at")
  failureCode            String?               @map("failure_code")
  failureMessage         String?               @map("failure_message")
  rawPayloadJson         Json?                 @map("raw_payload_json")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  settlementBatch      V1SettlementBatch @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)
  requestedByAdminUser V1AdminUser       @relation("V1PayoutAttemptRequestedBy", fields: [requestedByAdminUserId], references: [id], onDelete: Restrict)
  events               V1OpsCaseEvent[]

  @@index([settlementBatchId, createdAt])
  @@index([requestedByAdminUserId])
  @@index([status, createdAt])
  @@map("v1_payout_attempts")
}

model V1OpsCaseEvent {
  id                String             @id @default(uuid())
  eventType         V1OpsCaseEventType @map("event_type")
  reportId          String?            @map("report_id")
  disputeId         String?            @map("dispute_id")
  paymentOrderId    String?            @map("payment_order_id")
  refundId          String?            @map("refund_id")
  settlementBatchId String?            @map("settlement_batch_id")
  payoutAttemptId   String?            @map("payout_attempt_id")
  actorAdminUserId  String?            @map("actor_admin_user_id")
  actorUserId       String?            @map("actor_user_id")
  fromStatus        String?            @map("from_status")
  toStatus          String?            @map("to_status")
  reason            String?
  metadataJson      Json?              @map("metadata_json")
  createdAt         DateTime           @default(now()) @map("created_at")

  report          V1OpsReport?       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  dispute         V1OpsDispute?      @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  paymentOrder    V1PaymentOrder?    @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  refund          V1PaymentRefund?   @relation(fields: [refundId], references: [id], onDelete: Cascade)
  settlementBatch V1SettlementBatch? @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)
  payoutAttempt   V1PayoutAttempt?   @relation(fields: [payoutAttemptId], references: [id], onDelete: Cascade)
  actorAdminUser  V1AdminUser?       @relation("V1OpsCaseEventAdminActor", fields: [actorAdminUserId], references: [id], onDelete: SetNull)
  actorUser       V1User?            @relation("V1OpsCaseEventUserActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([reportId, createdAt])
  @@index([disputeId, createdAt])
  @@index([paymentOrderId, createdAt])
  @@index([refundId, createdAt])
  @@index([settlementBatchId, createdAt])
  @@index([payoutAttemptId, createdAt])
  @@index([actorAdminUserId, createdAt])
  @@map("v1_ops_case_events")
}

model V1StatusChangeLog {
  id          String            @id @default(uuid())
  targetType  String            @map("target_type")
  targetId    String            @map("target_id")
  fromStatus  String?           @map("from_status")
  toStatus    String            @map("to_status")
  actorType   V1StatusActorType @map("actor_type")
  actorUserId String?           @map("actor_user_id")
  adminUserId String?           @map("admin_user_id")
  reason      String?
  createdAt   DateTime          @default(now()) @map("created_at")

  actorUser V1User?      @relation("V1StatusActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  adminUser V1AdminUser? @relation("V1StatusAdminActor", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId])
  @@index([adminUserId])
  @@map("v1_status_change_logs")
}
