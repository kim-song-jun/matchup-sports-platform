# Database
DB_USER=teameet
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=teameet

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# Next.js server-side internal API origin
INTERNAL_API_ORIGIN=http://api:8100

# OAuth (선택사항)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Payment (leave blank to keep payments in mock mode)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# Deploy-safe canonical mock sync (disable only with literal "false")
DEPLOY_SYNC_MOCK_DATA=true

# WebSocket CORS allowed origins (comma-separated, e.g. https://yourdomain.com,https://www.yourdomain.com)
# Leave blank to fall back to allowing all origins (prints a warning — set this for production security)
REALTIME_ALLOWED_ORIGINS=
