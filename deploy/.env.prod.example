# Database
DB_USER=teameet
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=teameet

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# Next.js server-side internal API origin
INTERNAL_API_ORIGIN=http://api:8100

# Optional V1 preview runtime at /v1
# Defaults reuse DB_PASSWORD/JWT_SECRET when these are left blank in deploy/.env.
V1_DB_USER=teameet_v1
V1_DB_PASSWORD=
V1_DB_NAME=teameet_v1
V1_JWT_SECRET=
V1_INTERNAL_API_ORIGIN=http://v1_api:8121

# v1 은 x-v1-user-id/x-v1-user-email 헤더를 검증 없이 신뢰하는 dev 전용 인증을 사용합니다.
# 프로덕션(NODE_ENV=production) 부팅 시 기본은 fail-closed 입니다 — 이 값이 정확히 "true" 가
# 아니면 부팅이 즉시 중단됩니다. 서명 세션 인증으로 전환하기 전까지 임시로 헤더 인증을
# 허용해야 한다면(위험을 인지하고) 아래를 true 로 설정하세요.
V1_ALLOW_HEADER_AUTH=

# OAuth (선택사항)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://teameet.co.kr/callback/kakao
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Octomo 휴대폰 본인인증 (alpha 전용). 비우면 인증 기능 비활성(기존 가입 동작 유지).
# 키는 옥토모 마이페이지에서 발급. 서버 전용 — 절대 NEXT_PUBLIC_* 로 노출 금지.
OCTOMO_API_KEY=
OCTOMO_DEST_NUMBER=16663538

# Payment (leave blank to keep payments in mock mode)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# Web Push (VAPID). Leave any of the three blank to keep WebPushService
# gracefully disabled (no crash, push notifications no-op).
# Generate: node -e "const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys(), null, 2))"
# Full setup/rotation/rollback procedure: docs/ops/vapid-setup.md
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Deploy-safe canonical mock sync (disable only with literal "false")
DEPLOY_SYNC_MOCK_DATA=true

# V1 preview seed sync (disable only with literal "false")
DEPLOY_SYNC_V1_SEED_DATA=true

# V1 host admin email-login password (8+ chars).
# If left blank, seed.ts uses 11111111 for host@teameet.v1.
V1_HOST_ADMIN_PASSWORD=

# WebSocket CORS allowed origins (comma-separated, e.g. https://yourdomain.com,https://www.yourdomain.com)
# Leave blank to fall back to allowing all origins (prints a warning — set this for production security)
REALTIME_ALLOWED_ORIGINS=
