{
  "name": "teameet",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "autoqa": "node scripts/qa/run-autoqa.mjs",
    "autoqa:status": "node scripts/qa/run-autoqa.mjs status",
    "autoqa:scenarios": "node scripts/qa/run-autoqa-scenarios.mjs all",
    "autoqa:cycle": "node scripts/qa/run-autoqa-cycle.mjs cycle all",
    "autoqa:cron": "node scripts/qa/run-autoqa.mjs cron",
    "autoqa:cron:install": "node scripts/qa/run-autoqa.mjs cron install",
    "autoqa:cron:status": "node scripts/qa/run-autoqa.mjs cron status",
    "qa:v1-db-guardrails": "node scripts/qa/check-v1-db-guardrails.mjs",
    "qa:v1:stack:up": "docker compose -p teameet-v1-qa -f docker-compose.yml -f deploy/docker-compose.v1-qa.yml up -d --build deps v1_postgres v1_api v1_web",
    "qa:v1:stack:down": "docker compose -p teameet-v1-qa -f docker-compose.yml -f deploy/docker-compose.v1-qa.yml down",
    "qa:v1:home-notice": "docker compose -p teameet-v1-qa -f docker-compose.yml -f deploy/docker-compose.v1-qa.yml run --rm qa_runner",
    "qa:v1:popup-crud": "docker compose -p teameet-v1-qa -f docker-compose.yml -f deploy/docker-compose.v1-qa.yml run --rm qa_runner node scripts/qa/v1-popup-crud-qa.mjs",
    "qa:v1:home-notice:local": "node scripts/qa/v1-home-notice-popup-qa.mjs",
    "db:push": "pnpm --filter api db:push",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:bootstrap:deploy": "pnpm --filter api db:bootstrap:deploy",
    "db:studio": "pnpm --filter api db:studio",
    "db:seed": "pnpm --filter api db:seed",
    "db:seed:mocks": "pnpm --filter api db:seed:mocks",
    "db:seed:mocks:deploy": "pnpm --filter api db:seed:mocks:deploy",
    "db:seed:all": "pnpm db:seed && pnpm db:seed:mocks && pnpm --filter api db:seed:images",
    "v1:db:generate": "pnpm --filter v1_api db:generate",
    "v1:db:push": "pnpm --filter v1_api db:push",
    "v1:db:migrate": "pnpm --filter v1_api db:migrate",
    "v1:db:studio": "pnpm --filter v1_api db:studio",
    "v1:db:seed": "pnpm --filter v1_api db:seed",
    "v1:db:seed:demo": "pnpm --filter v1_api db:seed:demo",
    "v1:db:seed:all": "pnpm --filter v1_api db:seed:all",
    "v1:db:seed:event-campaigns": "pnpm --filter v1_api db:seed:event-campaigns",
    "v1:db:cleanup:demo": "pnpm --filter v1_api db:cleanup:demo",
    "v1:test": "pnpm --filter v1_api test && pnpm --filter v1_web test",
    "test:e2e:v1": "pnpm exec playwright test --config=e2e/v1.config.ts",
    "test:e2e": "pnpm exec playwright test --config=e2e/playwright.config.ts",
    "test:all": "pnpm --filter api test && pnpm --filter web test && pnpm exec playwright test --config=e2e/playwright.config.ts",
    "qa:manual:routes": "node scripts/qa/manual-route-smoke.mjs",
    "qa:manual:ui-gaps": "node scripts/qa/manual-ui-gap-audit.mjs",
    "qa:visual:audit:manifest": "node scripts/qa/run-visual-audit.mjs manifest",
    "qa:visual:audit:capture": "node scripts/qa/run-visual-audit.mjs capture",
    "qa:e2e:analyzer": "node scripts/qa/run-e2e-analyzer.mjs",
    "qa:e2e:analyzer:tick": "node scripts/qa/run-e2e-analyzer.mjs tick",
    "qa:e2e:analyzer:watch": "node scripts/qa/run-e2e-analyzer.mjs watch",
    "docs:screenshots:overview": "node scripts/docs/capture-overview-screenshots.mjs",
    "docs:screenshots:app": "node scripts/docs/capture-app-screenshots.mjs"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "turbo": "^2.8.19"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
